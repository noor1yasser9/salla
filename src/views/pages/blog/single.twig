{% extends 'layouts.master' %}

{% block title %}{{ post.title }} | {{ store.name }}{% endblock %}
{% block description %}{{ post.excerpt | default(post.content | striptags | truncate(160)) }}{% endblock %}
{% block og_title %}{{ post.title }}{% endblock %}
{% block og_description %}{{ post.excerpt | default(post.content | striptags | truncate(160)) }}{% endblock %}
{% block og_image %}{{ post.image }}{% endblock %}

{% block content %}
<div class="container" style="padding:40px 20px;">

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <ol class="breadcrumb-list">
      <li class="breadcrumb-item"><a href="{{ store.url }}">الرئيسية</a></li>
      <li class="breadcrumb-item"><a href="{{ store.url }}/blog">{{ trans('blog.title') }}</a></li>
      <li class="breadcrumb-item active" aria-current="page">{{ post.title | truncate(40) }}</li>
    </ol>
  </nav>

  <div style="display:grid;grid-template-columns:1fr 300px;gap:40px;margin-top:32px;">

    {# Main Article #}
    <article itemscope itemtype="https://schema.org/BlogPosting">
      {% if post.image %}
        <img src="{{ post.image }}" alt="{{ post.title }}" style="width:100%;border-radius:var(--radius);margin-bottom:28px;" loading="eager" itemprop="image">
      {% endif %}
      <h1 style="font-size:2rem;margin-bottom:16px;" itemprop="headline">{{ post.title }}</h1>
      <div style="display:flex;align-items:center;gap:16px;color:var(--text-muted);font-size:0.875rem;margin-bottom:28px;padding-bottom:20px;border-bottom:1px solid var(--border);">
        {% if post.author is defined %}<span itemprop="author"><i class="fas fa-user-circle"></i> {{ post.author }}</span>{% endif %}
        {% if post.published_at is defined %}<span><i class="fas fa-calendar"></i> <time datetime="{{ post.published_at }}" itemprop="datePublished">{{ post.published_at | date("d/m/Y") }}</time></span>{% endif %}
        {% if post.category is defined %}<span><i class="fas fa-folder"></i> {{ post.category.name }}</span>{% endif %}
      </div>
      <div class="post-content" style="line-height:2;font-size:1rem;" itemprop="articleBody">
        {{ post.content | raw }}
      </div>

      {# Tags #}
      {% if post.tags is defined and post.tags | length %}
      <div style="margin-top:32px;padding-top:20px;border-top:1px solid var(--border);">
        <span style="font-weight:600;margin-inline-end:8px;">{{ trans('blog.tags') }}:</span>
        {% for tag in post.tags %}
          <a href="{{ store.url }}/blog?tag={{ tag.slug }}" style="display:inline-block;background:var(--bg-alt);border-radius:50px;padding:4px 14px;font-size:0.8rem;margin:4px;">{{ tag.name }}</a>
        {% endfor %}
      </div>
      {% endif %}

      {# Social Share #}
      <div style="margin-top:28px;display:flex;align-items:center;gap:12px;">
        <span style="font-weight:600;">{{ trans('blog.share') }}:</span>
        <a href="https://wa.me/?text={{ (post.title ~ ' ' ~ request.url) | url_encode }}" target="_blank" rel="noopener" style="color:#25d366;"><i class="fab fa-whatsapp fa-xl"></i></a>
        <a href="https://twitter.com/intent/tweet?url={{ request.url | url_encode }}&text={{ post.title | url_encode }}" target="_blank" rel="noopener" style="color:#1da1f2;"><i class="fab fa-twitter fa-xl"></i></a>
        <a href="https://www.facebook.com/sharer/sharer.php?u={{ request.url | url_encode }}" target="_blank" rel="noopener" style="color:#1877f2;"><i class="fab fa-facebook fa-xl"></i></a>
      </div>
    </article>

    {# Sidebar #}
    <aside>
      {% if related_posts is defined and related_posts | length %}
      <div style="background:var(--bg-alt);border-radius:var(--radius);padding:24px;">
        <h3 style="font-size:1rem;margin-bottom:16px;padding-bottom:12px;border-bottom:2px solid var(--primary);">مقالات ذات صلة</h3>
        {% for related in related_posts %}
        <div style="display:flex;gap:12px;margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid var(--border);">
          {% if related.image %}
            <img src="{{ related.image }}" alt="{{ related.title }}" style="width:70px;height:60px;object-fit:cover;border-radius:var(--radius-sm);flex-shrink:0;">
          {% endif %}
          <div>
            <a href="{{ related.url }}" style="font-size:0.875rem;font-weight:600;line-height:1.4;">{{ related.title | truncate(60) }}</a>
            {% if related.published_at is defined %}
              <p style="font-size:0.75rem;color:var(--text-muted);margin-top:4px;">{{ related.published_at | date("d/m/Y") }}</p>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
      {% endif %}
    </aside>

  </div>
</div>
{% endblock %}

