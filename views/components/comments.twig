{# ── Comments / Reviews Component ─────────────────────────────────────────── #}
<div class="comments-section" aria-labelledby="comments-title">

  <h3 id="comments-title" style="font-size:1.2rem;margin-bottom:24px;">
    التقييمات والتعليقات
    {% if comments is defined %}
      <span style="font-size:0.875rem;color:var(--text-muted);font-weight:400;">({{ comments | length }})</span>
    {% endif %}
  </h3>

  {# Rating Summary #}
  {% if average_rating is defined %}
  <div style="display:flex;align-items:center;gap:20px;padding:20px;background:var(--bg-alt);border-radius:var(--radius);margin-bottom:28px;">
    <div style="text-align:center;">
      <div style="font-size:3rem;font-weight:800;color:var(--primary);">{{ average_rating | round(1) }}</div>
      <div style="display:flex;gap:2px;justify-content:center;margin-top:4px;">
        {% for i in 1..5 %}
          <i class="fa{% if i <= average_rating %}s{% else %}r{% endif %} fa-star" style="color:#ffc107;"></i>
        {% endfor %}
      </div>
      <div style="font-size:0.8rem;color:var(--text-muted);margin-top:4px;">من 5</div>
    </div>
  </div>
  {% endif %}

  {# Comments List #}
  {% if comments is defined and comments | length %}
    <div style="display:flex;flex-direction:column;gap:20px;">
      {% for comment in comments %}
      <div style="padding:20px;border:1px solid var(--border);border-radius:var(--radius);background:var(--bg);">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
          <div style="display:flex;align-items:center;gap:10px;">
            <div style="width:40px;height:40px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;">
              {{ comment.author | first | upper }}
            </div>
            <div>
              <div style="font-weight:600;font-size:0.9rem;">{{ comment.author }}</div>
              {% if comment.created_at is defined %}
                <div style="font-size:0.75rem;color:var(--text-muted);">{{ comment.created_at | date("d/m/Y") }}</div>
              {% endif %}
            </div>
          </div>
          {% if comment.rating is defined %}
            <div style="display:flex;gap:2px;">
              {% for i in 1..5 %}
                <i class="fa{% if i <= comment.rating %}s{% else %}r{% endif %} fa-star" style="color:#ffc107;font-size:0.8rem;"></i>
              {% endfor %}
            </div>
          {% endif %}
        </div>
        <p style="font-size:0.9rem;line-height:1.8;color:var(--text);">{{ comment.content }}</p>
      </div>
      {% endfor %}
    </div>
  {% else %}
    <div style="text-align:center;padding:40px;color:var(--text-muted);">
      <i class="far fa-comment-dots" style="font-size:2.5rem;margin-bottom:12px;display:block;opacity:0.4;"></i>
      <p>لا توجد تعليقات بعد. كن أول من يعلّق!</p>
    </div>
  {% endif %}

  {# Add Comment Form #}
  {% if customer is defined and customer %}
  <div style="margin-top:32px;padding:24px;background:var(--bg-alt);border-radius:var(--radius);">
    <h4 style="margin-bottom:20px;">أضف تقييمك</h4>
    <salla-add-rating>
      <form method="post" novalidate>
        <div style="display:flex;gap:8px;margin-bottom:16px;" role="radiogroup" aria-label="Rating">
          {% for i in 1..5 %}
            <label style="cursor:pointer;font-size:1.6rem;color:#d4d4d4;transition:color 0.2s;" title="{{ i }} نجوم">
              <input type="radio" name="rating" value="{{ i }}" style="display:none;">⭐
            </label>
          {% endfor %}
        </div>
        <div class="form-group" style="margin-bottom:16px;">
          <textarea name="content" rows="4" placeholder="اكتب تعليقك هنا..." style="width:100%;padding:12px 16px;border:2px solid var(--border);border-radius:var(--radius-sm);resize:vertical;font-size:0.9rem;" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary">إرسال التقييم</button>
      </form>
    </salla-add-rating>
  </div>
  {% else %}
    <div style="text-align:center;padding:20px;margin-top:20px;background:var(--bg-alt);border-radius:var(--radius);">
      <p style="margin-bottom:12px;color:var(--text-muted);">يجب تسجيل الدخول لإضافة تقييم</p>
      <a href="{{ store.url }}/customer/login" class="btn btn-outline btn-sm">{{ trans('header.login') }}</a>
    </div>
  {% endif %}

</div>

