{#
| Variable              | Type      | Description                              |
|-----------------------|-----------|------------------------------------------|
| items[].title         | string    | Tab title                                |
| items[].products[]    | Product[] | Products in this tab                     |
| items[].id            | string    | Tab id                                   |
| position              | int       | Block position index                     |
#}
{% set component_id = 'featured-products-' ~ position %}
<section class="s-block products-section" id="{{ component_id }}">
    <div class="container">

        {# Section Header #}
        <div class="section-header">
            <div>
                {% if component.title %}
                    <h2 class="section-title">{{ component.title }}</h2>
                {% endif %}
            </div>
            {% if component.display_all_url and theme.settings.get('is_more_button_enabled') %}
                <a href="{{ component.display_all_url }}" class="btn btn-outline btn-sm">
                    {{ trans('blocks.home.display_all') }}
                </a>
            {% endif %}
        </div>

        {# Tabs Navigation - uses same data-tab system as app.js #}
        {% if items | length > 1 %}
        <div class="product-tabs" style="border-top:none;padding-top:0;">
            <div class="tabs-nav" style="margin-bottom:24px;">
                {% for section in items %}
                    <button
                        class="tab-btn {% if loop.first %}active{% endif %}"
                        data-tab="{{ component_id }}-{{ section.id }}"
                    >
                        {{ section.title }}
                    </button>
                {% endfor %}
            </div>

            {# Tab Contents #}
            {% for section in items %}
                <div id="{{ component_id }}-{{ section.id }}"
                     class="tab-content {% if loop.first %}active{% endif %}">
                    <div class="products-grid">
                        {% for product in section.products | slice(0, 8) %}
                            {% include 'pages/partials/product/card.twig' with { 'product': product } %}
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}
        </div>

        {% else %}
            {# Single tab - show directly without nav #}
            {% if items | length %}
                <div class="products-grid">
                    {% for product in items[0].products | slice(0, 8) %}
                        {% include 'pages/partials/product/card.twig' with { 'product': product } %}
                    {% endfor %}
                </div>
            {% endif %}
        {% endif %}

    </div>
</section>
