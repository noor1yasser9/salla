<header class="site-header" role="banner">
  <div class="container">
    <div class="header-inner">

      {# Logo #}
      <a href="{{ store.url }}" class="header-logo" aria-label="{{ store.name }}">
        {% if store.logo %}
          <img src="{{ store.logo }}" alt="{{ store.name }}" width="160" height="48" loading="eager">
        {% else %}
          <span class="store-name">{{ store.name }}</span>
        {% endif %}
      </a>

      {# Search Bar (Desktop) #}
      {% if settings.header.show_search %}
      <form class="header-search" action="{{ store.url }}/search" method="get" role="search">
        <i class="fas fa-search search-icon" aria-hidden="true"></i>
        <input
          type="search"
          name="q"
          placeholder="{{ trans('common.search_placeholder') }}"
          value="{{ request.query.q }}"
          autocomplete="off"
          aria-label="{{ trans('common.search_placeholder') }}"
        >
      </form>
      {% endif %}

      {# Header Actions #}
      <div class="header-actions">

        {# Mobile Search Toggle #}
        <button class="header-action-btn search-toggle d-lg-none" aria-label="{{ trans('header.search') }}">
          <i class="fas fa-search"></i>
        </button>

        {# Wishlist #}
        <a href="{{ store.url }}/wishlist" class="header-action-btn" aria-label="{{ trans('header.wishlist') }}">
          <salla-button fill="none" shape="icon" aria-label="{{ trans('header.wishlist') }}">
            <i class="far fa-heart"></i>
          </salla-button>
          <span class="badge" id="wishlist-count">{{ customer.wishlist_count ?? 0 }}</span>
          <span>{{ trans('header.wishlist') }}</span>
        </a>

        {# Cart #}
        <a href="{{ store.url }}/cart" class="header-action-btn" aria-label="{{ trans('header.cart') }}">
          <salla-cart-icon>
            <i class="fas fa-shopping-cart"></i>
          </salla-cart-icon>
          <span>{{ trans('header.cart') }}</span>
        </a>

        {# Account #}
        {% if customer %}
          <a href="{{ store.url }}/customer/profile" class="header-action-btn" aria-label="{{ trans('header.account') }}">
            <i class="far fa-user-circle"></i>
            <span>{{ customer.first_name }}</span>
          </a>
        {% else %}
          <a href="{{ store.url }}/customer/login" class="header-action-btn btn btn-primary btn-sm">
            <i class="fas fa-sign-in-alt"></i>
            {{ trans('header.login') }}
          </a>
        {% endif %}

        {# Mobile Menu Toggle #}
        <button class="header-action-btn mobile-menu-toggle d-xl-none" aria-label="{{ trans('header.menu') }}" aria-expanded="false">
          <i class="fas fa-bars"></i>
        </button>

      </div>
    </div>
  </div>

  {# Mobile Search Bar #}
  <div class="header-search-mobile">
    <div class="container">
      <form action="{{ store.url }}/search" method="get">
        <input type="search" name="q" placeholder="{{ trans('common.search_placeholder') }}" value="{{ request.query.q }}">
        <button type="submit"><i class="fas fa-search"></i></button>
      </form>
    </div>
  </div>
</header>

{# Navigation Bar #}
<nav class="site-nav" aria-label="Main navigation">
  <div class="container">
    <ul class="nav-inner" role="list">

      {# All Categories Mega-Menu Trigger #}
      <li class="nav-item">
        <a href="{{ store.url }}/categories" class="nav-link">
          <i class="fas fa-th-large"></i> {{ trans('header.categories') }}
        </a>
        {% if categories is defined and categories|length %}
        <div class="nav-dropdown">
          {% for category in categories %}
            <a href="{{ category.url }}">
              {% if category.image %}<img src="{{ category.image }}" alt="{{ category.name }}" width="20" height="20" loading="lazy">{% endif %}
              {{ category.name }}
            </a>
          {% endfor %}
        </div>
        {% endif %}
      </li>

      {# Store Menu Links #}
      {% if menus is defined %}
        {% for item in menus %}
        <li class="nav-item">
          <a href="{{ item.url }}" class="nav-link {% if request.url == item.url %}active{% endif %}">
            {{ item.name }}
            {% if item.children is defined and item.children|length %}
              <i class="fas fa-chevron-down" style="font-size:0.7rem;"></i>
            {% endif %}
          </a>
          {% if item.children is defined and item.children|length %}
          <div class="nav-dropdown">
            {% for child in item.children %}
              <a href="{{ child.url }}">{{ child.name }}</a>
            {% endfor %}
          </div>
          {% endif %}
        </li>
        {% endfor %}
      {% endif %}

      {# Brands Link #}
      <li class="nav-item">
        <a href="{{ store.url }}/brands" class="nav-link">{{ trans('header.brands') }}</a>
      </li>

    </ul>
  </div>
</nav>

{# Mobile Navigation Drawer #}
<div class="mobile-nav" aria-hidden="true">
  <div class="mobile-nav-header">
    <span class="mobile-nav-title">{{ trans('header.menu') }}</span>
    <button class="mobile-menu-toggle" aria-label="{{ trans('common.close') }}"><i class="fas fa-times"></i></button>
  </div>
  <ul>
    <li><a href="{{ store.url }}"><i class="fas fa-home"></i> الرئيسية</a></li>
    <li><a href="{{ store.url }}/categories"><i class="fas fa-th"></i> {{ trans('header.categories') }}</a></li>
    <li><a href="{{ store.url }}/brands"><i class="fas fa-award"></i> {{ trans('header.brands') }}</a></li>
    {% if customer %}
      <li><a href="{{ store.url }}/customer/profile"><i class="far fa-user"></i> {{ trans('customer.profile') }}</a></li>
      <li><a href="{{ store.url }}/orders"><i class="fas fa-box"></i> {{ trans('orders.title') }}</a></li>
      <li><a href="{{ store.url }}/wishlist"><i class="far fa-heart"></i> {{ trans('customer.wishlist') }}</a></li>
    {% else %}
      <li><a href="{{ store.url }}/customer/login"><i class="fas fa-sign-in-alt"></i> {{ trans('header.login') }}</a></li>
    {% endif %}
  </ul>
</div>
<div class="mobile-nav-overlay"></div>

