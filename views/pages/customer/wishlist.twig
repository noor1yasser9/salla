{% extends 'layouts/master.twig' %}

{% block title %}{{ trans('customer.wishlist') }} | {{ store.name }}{% endblock %}

{% block content %}
<div class="container customer-page">
  <div class="customer-grid">

    {# Sidebar #}
    <aside class="customer-sidebar">
      <nav class="customer-nav">
        <a href="{{ store.url }}/customer/profile"><i class="fas fa-user"></i> {{ trans('customer.profile') }}</a>
        <a href="{{ store.url }}/orders"><i class="fas fa-box"></i> {{ trans('orders.title') }}</a>
        <a href="{{ store.url }}/wishlist" class="active"><i class="far fa-heart"></i> {{ trans('customer.wishlist') }}</a>
        <a href="{{ store.url }}/customer/notifications"><i class="fas fa-bell"></i> {{ trans('customer.notifications') }}</a>
      </nav>
    </aside>

    {# Wishlist Content #}
    <div class="customer-content">
      <h2 style="font-size:1.4rem;margin-bottom:28px;padding-bottom:16px;border-bottom:2px solid var(--primary);">{{ trans('customer.wishlist') }}</h2>

      {% if wishlist is defined and wishlist | length %}
        <div class="products-grid" style="grid-template-columns:repeat(3,1fr);">
          {% for item in wishlist %}
            {% include 'components/product/card.twig' with { 'product': item.product ?? item } %}
          {% endfor %}
        </div>
      {% else %}
        <div class="empty-state">
          <div class="empty-state-icon">💝</div>
          <h3>{{ trans('customer.no_wishlist') }}</h3>
          <p style="color:var(--text-muted);">ابدأ بإضافة المنتجات إلى قائمة مفضلتك</p>
          <a href="{{ store.url }}/products" class="btn btn-primary">{{ trans('common.view_all') }}</a>
        </div>
      {% endif %}
    </div>

  </div>
</div>
{% endblock %}

