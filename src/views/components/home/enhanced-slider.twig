{#
| Variable                       | Type     | Description              |
|--------------------------------|----------|--------------------------|
| component.slides[].image       | string   | Image url                |
| component.slides[].title       | ?string  | Slide title              |
| component.slides[].description | ?string  | Slide description        |
| component.slides[].without_overlay | bool | Remove dark overlay     |
| position                       | int      | Block position index     |
#}
<section class="s-block s-block--hero-slider s-block--full-bg">
    <salla-slider
        id="main-slider-{{ position }}"
        auto-play
        static-when-single
        {{ component.slides|length > 1 ? '' : 'show-controls="false"' }}
        type="fullwidth">
        <div slot="items">
            {% for slide in component.slides %}
                <div class="swiper-slide" style="min-height:420px;position:relative;background:#1d6ae5;">
                    <div style="background-image:url({{ slide.image }});background-size:cover;background-position:center;position:absolute;inset:0;{{ slide.without_overlay ? '' : 'background-color:rgba(0,0,0,0.35);background-blend-mode:multiply;' }}"></div>
                    <div style="position:relative;z-index:1;display:flex;align-items:center;justify-content:center;min-height:420px;padding:40px 20px;">
                        <div style="text-align:center;color:#fff;max-width:560px;">
                            {% if slide.title %}
                                <h2 style="font-size:2.4rem;font-weight:800;margin-bottom:16px;line-height:1.3;">{{ slide.title }}</h2>
                            {% endif %}
                            {% if slide.description %}
                                <p style="font-size:1.1rem;opacity:0.9;margin-bottom:28px;">{{ slide.description }}</p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </salla-slider>
</section>

