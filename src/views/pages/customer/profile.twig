{% extends 'layouts.master' %}

{% block title %}{{ trans('customer.profile') }} | {{ store.name }}{% endblock %}
{% block body_class %}customer-page-body{% endblock %}

{% block content %}
<div class="container customer-page">
  <div class="customer-grid">

    {# Sidebar Navigation #}
    <aside class="customer-sidebar" aria-label="Account Navigation">
      {% if customer.avatar %}
        <div style="text-align:center;margin-bottom:20px;">
          <img src="{{ customer.avatar }}" alt="{{ customer.first_name }}" style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:3px solid var(--primary);">
          <div style="font-weight:700;margin-top:8px;">{{ customer.first_name }} {{ customer.last_name }}</div>
          <div style="font-size:0.8rem;color:var(--text-muted);">{{ customer.email }}</div>
        </div>
      {% endif %}
      <nav class="customer-nav">
        <a href="{{ store.url }}/customer/profile" class="active"><i class="fas fa-user"></i> {{ trans('customer.profile') }}</a>
        <a href="{{ store.url }}/orders"><i class="fas fa-box"></i> {{ trans('orders.title') }}</a>
        <a href="{{ store.url }}/wishlist"><i class="far fa-heart"></i> {{ trans('customer.wishlist') }}</a>
        <a href="{{ store.url }}/customer/notifications"><i class="fas fa-bell"></i> {{ trans('customer.notifications') }}</a>
        <a href="{{ store.url }}/customer/logout" style="color:#dc3545;"><i class="fas fa-sign-out-alt"></i> {{ trans('header.logout') }}</a>
      </nav>
    </aside>

    {# Profile Content #}
    <div class="customer-content">
      <h2 style="font-size:1.4rem;margin-bottom:28px;padding-bottom:16px;border-bottom:2px solid var(--primary);">{{ trans('customer.profile') }}</h2>

      <salla-profile>
        <form method="post" action="{{ store.url }}/customer/profile" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="first_name">{{ trans('customer.name') }} (الأول)</label>
              <input type="text" id="first_name" name="first_name" value="{{ customer.first_name }}" required>
            </div>
            <div class="form-group">
              <label for="last_name">{{ trans('customer.name') }} (الأخير)</label>
              <input type="text" id="last_name" name="last_name" value="{{ customer.last_name }}">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="email">{{ trans('customer.email') }}</label>
              <input type="email" id="email" name="email" value="{{ customer.email }}" required>
            </div>
            <div class="form-group">
              <label for="phone">{{ trans('customer.phone') }}</label>
              <input type="tel" id="phone" name="phone" value="{{ customer.phone }}">
            </div>
          </div>
          <div class="form-group">
            <label for="birth_date">تاريخ الميلاد</label>
            <input type="date" id="birth_date" name="birth_date" value="{{ customer.birth_date }}">
          </div>
          <button type="submit" class="btn btn-primary">{{ trans('customer.save_changes') }}</button>
        </form>
      </salla-profile>
    </div>

  </div>
</div>
{% endblock %}

