<article class="product-card" itemscope itemtype="https://schema.org/Product">
  <div class="product-card-image">

    {# Product Image #}
    <a href="{{ product.url }}" aria-label="{{ product.name }}" tabindex="-1">
      <img
        src="{{ product.thumbnail | default(product.main_image) }}"
        alt="{{ product.name }}"
        loading="lazy"
        width="300" height="300"
        itemprop="image"
        onerror="this.src='{{ 'images/placeholder.png' | asset }}'"
      >
    </a>

    {# Discount Badge #}
    {% if product.discount is defined and product.discount %}
      <span class="product-badge">-{{ product.discount }}%</span>
    {% elseif product.is_new is defined and product.is_new %}
      <span class="product-badge" style="background:var(--primary);">جديد</span>
    {% elseif product.is_on_sale is defined and product.is_on_sale %}
      <span class="product-badge">تخفيض</span>
    {% endif %}

    {# Wishlist Button #}
    <salla-button
      class="product-card-wishlist"
      fill="none"
      shape="icon"
      data-id="{{ product.id }}"
      aria-label="{{ trans('common.add_to_wishlist') }}"
    >
      <i class="far fa-heart"></i>
    </salla-button>

  </div>

  <div class="product-card-body">

    {# Brand #}
    {% if product.brand is defined and product.brand %}
      <div class="product-card-brand" itemprop="brand">{{ product.brand.name }}</div>
    {% endif %}

    {# Product Name #}
    <h3 class="product-card-name" itemprop="name">
      <a href="{{ product.url }}">{{ product.name | truncate(60) }}</a>
    </h3>

    {# Rating #}
    {% if product.rating is defined and product.rating %}
    <div class="product-info-rating" style="margin-bottom:8px;">
      {% for i in 1..5 %}
        <i class="fa{% if i <= product.rating %}s{% else %}r{% endif %} fa-star" style="color:#ffc107;font-size:0.75rem;"></i>
      {% endfor %}
      {% if product.reviews_count is defined %}
        <span style="font-size:0.75rem;color:var(--text-muted);">({{ product.reviews_count }})</span>
      {% endif %}
    </div>
    {% endif %}

    {# Price #}
    <div class="product-card-price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
      <span class="product-price" itemprop="price">
        {{ product.price | money }}
      </span>
      {% if product.old_price is defined and product.old_price and product.old_price != product.price %}
        <span class="product-price-old">{{ product.old_price | money }}</span>
      {% endif %}
      <meta itemprop="priceCurrency" content="{{ store.currency }}">
      <meta itemprop="availability" content="{{ product.is_available ? 'InStock' : 'OutOfStock' }}">
    </div>

    {# Stock Status #}
    {% if not product.is_available %}
      <p style="font-size:0.78rem;color:#dc3545;margin-bottom:8px;">{{ trans('product.out_of_stock') }}</p>
    {% endif %}

    {# Actions #}
    <div class="product-card-actions">
      {% if product.is_available %}
        <salla-add-product-button
          product-id="{{ product.id }}"
          class="btn btn-primary"
          style="flex:1;"
        >
          <i class="fas fa-shopping-cart"></i> {{ trans('common.add_to_cart') }}
        </salla-add-product-button>
      {% else %}
        <button class="btn btn-outline" disabled style="flex:1;">{{ trans('product.out_of_stock') }}</button>
      {% endif %}
      <a href="{{ product.url }}" class="btn btn-outline">
        <i class="fas fa-eye"></i>
      </a>
    </div>

  </div>
</article>

