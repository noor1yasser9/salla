<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">

      {# Brand Column #}
      <div class="footer-widget">
        <div class="footer-brand">
          {% if store.logo %}
            <img src="{{ store.logo }}" alt="{{ store.name }}" height="48" style="margin-bottom:12px;filter:brightness(0) invert(1);">
          {% else %}
            <div class="logo">{{ store.name }}</div>
          {% endif %}
          {% if store.description %}
            <p>{{ store.description | raw }}</p>
          {% endif %}
        </div>
        {# Social Media - Salla Component #}
        <salla-social class="block mt-4"></salla-social>
        {# Trust Badges - Salla Component #}
        <salla-trust-badges></salla-trust-badges>
      </div>

      {# Footer Links - Salla Component #}
      <div class="footer-widget">
        <h4>{{ trans('blocks.footer.pages_links') }}</h4>
        <salla-menu source="footer"></salla-menu>
      </div>

      {# Contact Info - Salla Component #}
      <div class="footer-widget">
        <salla-contacts></salla-contacts>
      </div>

      {# App Store Icons & Newsletter - Salla Components #}
      <div class="footer-widget">
        <salla-apps-icons></salla-apps-icons>
      </div>

    </div>{# /.footer-grid #}
  </div>

  {# Footer Bottom: copyright + Payment Methods #}
  <div class="footer-bottom">
    <div class="container">
      <span class="text-sm">{% hook copyright %}</span>
      {# Payment Methods - Salla Component (fixes Mixed Content error) #}
      <salla-payments></salla-payments>
    </div>
  </div>

</footer>

