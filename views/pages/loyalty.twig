{% extends 'layouts/master.twig' %}

{% block title %}برنامج الولاء | {{ store.name }}{% endblock %}
{% block description %}برنامج نقاط المكافآت والولاء - {{ store.name }}{% endblock %}

{% block content %}
<div class="container" style="padding:60px 20px;">

  <div style="text-align:center;max-width:700px;margin:0 auto 48px;">
    <div style="font-size:4rem;margin-bottom:16px;">🏆</div>
    <h1 style="font-size:2.2rem;margin-bottom:12px;">برنامج الولاء</h1>
    <p style="font-size:1.1rem;color:var(--text-muted);">اكسب نقاطاً مع كل عملية شراء واستبدلها بخصومات حصرية</p>
  </div>

  {# Loyalty Points Component #}
  <salla-loyalty-points>
    {% if customer is defined and customer %}
    <div style="max-width:480px;margin:0 auto;background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff;border-radius:var(--radius);padding:32px;text-align:center;box-shadow:0 12px 40px rgba(108,99,255,0.3);">
      <div style="font-size:0.9rem;opacity:0.85;margin-bottom:8px;">رصيد نقاطك الحالي</div>
      <div style="font-size:3.5rem;font-weight:800;">{{ loyalty.points | default(0) }}</div>
      <div style="font-size:0.875rem;opacity:0.8;margin-top:4px;">نقطة</div>
      {% if loyalty.points_value is defined %}
        <div style="margin-top:16px;background:rgba(255,255,255,0.15);border-radius:50px;padding:8px 20px;font-size:0.9rem;">
          تعادل {{ loyalty.points_value | money }}
        </div>
      {% endif %}
    </div>

    {# How it works #}
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:48px;">
      <div style="text-align:center;padding:28px;background:var(--bg-alt);border-radius:var(--radius);">
        <div style="font-size:2.5rem;margin-bottom:12px;">🛍️</div>
        <h3 style="margin-bottom:8px;">اشتري</h3>
        <p style="font-size:0.875rem;color:var(--text-muted);">اكسب نقطة مقابل كل ريال تنفقه</p>
      </div>
      <div style="text-align:center;padding:28px;background:var(--bg-alt);border-radius:var(--radius);">
        <div style="font-size:2.5rem;margin-bottom:12px;">💰</div>
        <h3 style="margin-bottom:8px;">اجمع</h3>
        <p style="font-size:0.875rem;color:var(--text-muted);">تراكم نقاطك مع كل عملية شراء</p>
      </div>
      <div style="text-align:center;padding:28px;background:var(--bg-alt);border-radius:var(--radius);">
        <div style="font-size:2.5rem;margin-bottom:12px;">🎁</div>
        <h3 style="margin-bottom:8px;">استبدل</h3>
        <p style="font-size:0.875rem;color:var(--text-muted);">استخدم نقاطك للحصول على خصومات</p>
      </div>
    </div>

    {% else %}
    <div class="empty-state">
      <div class="empty-state-icon">🏆</div>
      <h3>سجّل الدخول للاستفادة من برنامج الولاء</h3>
      <a href="{{ store.url }}/customer/login" class="btn btn-primary">{{ trans('header.login') }}</a>
    </div>
    {% endif %}
  </salla-loyalty-points>

</div>
{% endblock %}

